{
  "name": "tiginer-portal",
  "version": "2.0.0",
  "private": true,
  "description": "Tiginer product site and admin portal (Cloudflare Workers + R2 + KV)",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "kv:setup": "wrangler kv namespace create PORTAL_KV",
    "typecheck": "tsc --noEmit",
    "legacy:start": "node server.js"
  },
  "dependencies": {
    "hono": "^4.9.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.20.0"
  },
  "engines": {
    "node": ">=20"
  }
}
