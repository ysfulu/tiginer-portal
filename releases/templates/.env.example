# ============================================================
# Tiginer NMS — Ortam Degiskenleri
# Bu dosyayi .env olarak kopyalayin ve degerlerini doldurun.
# ============================================================

# ── Uygulama ─────────────────────────────────────────
APP_PORT=3002
NODE_ENV=production

# ── Veritabani Modu ───────────────────────────────────
# bundled  = PostgreSQL Docker container ile birlikte gelir (varsayilan)
# external = Kendi PostgreSQL sunucunuzu kullanin
DB_MODE=bundled

# ── PostgreSQL (bundled mod) ──────────────────────────
# DB_MODE=bundled ise asagidaki degerler kullanilir.
POSTGRES_USER=tiginer
POSTGRES_PASSWORD=BURAYA_GUCLU_SIFRE_GIRIN
POSTGRES_DB=tiginer
POSTGRES_PORT=5432

# ── PostgreSQL (external mod) ─────────────────────────
# DB_MODE=external ise asagidaki DATABASE_URL degerini doldurun.
# Bundled modda bos birakin, otomatik olusturulur.
#
# Ornek (SSL'siz):
#   DATABASE_URL=postgresql://kullanici:sifre@db-sunucu:5432/tiginer
#
# Ornek (SSL/TLS ile — isteğe bağlı):
#   DATABASE_URL=postgresql://kullanici:sifre@db-sunucu:5432/tiginer?sslmode=require
#
# SSL modlari: disable | allow | prefer | require | verify-ca | verify-full
# Kurumsal ortamda "require" veya "verify-full" onerilir.
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=BURAYA_REDIS_SIFRESI
REDIS_PORT=6379

# ── InfluxDB ──────────────────────────────────────────
INFLUXDB_PASSWORD=BURAYA_INFLUX_SIFRESI
INFLUXDB_TOKEN=BURAYA_INFLUX_TOKEN_GIRIN
INFLUXDB_ORG=tiginer
INFLUXDB_BUCKET=network_metrics
INFLUXDB_PORT=8086

# ── Guvenlik Anahtarlari ─────────────────────────────
# Asagidaki degerleri rastgele olusturun:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=BURAYA_RASTGELE_32_BYTE_HEX
NEXTAUTH_URL=http://localhost:3002
INTERNAL_API_SECRET=BURAYA_RASTGELE_32_BYTE_HEX
ENCRYPTION_KEY=BURAYA_RASTGELE_32_BYTE_HEX

# ── Lisans ────────────────────────────────────────────
# Tiginer lisans anahtarinizi girin (admin panelden alinir)
LICENSE_KEY=
LICENSE_SERVER_URL=https://tiginer.com
